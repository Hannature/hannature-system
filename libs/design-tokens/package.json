{
  "name": "@hannature/design-tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@hannature-system/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tailwind": {
      "@hannature-system/source": "./src/tailwind/preset.ts",
      "types": "./dist/tailwind/preset.d.ts",
      "import": "./dist/tailwind/preset.js",
      "default": "./dist/tailwind/preset.js"
    }
  },
  "nx": {
    "targets": {
      "test": {
        "executor": "@nx/vitest:test",
        "options": {
          "configFile": "libs/design-tokens/vitest.config.ts"
        }
      }
    },
    "tags": [
      "scope:shared",
      "type:util"
    ]
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  }
}
