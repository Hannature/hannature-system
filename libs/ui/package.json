{
  "name": "@hannature/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@hannature-system/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "targets": {
      "test": {
        "executor": "@nx/vitest:test",
        "options": {
          "configFile": "libs/ui/vitest.config.ts"
        }
      },
      "build-storybook": {
        "executor": "nx:run-commands",
        "dependsOn": ["^build"],
        "options": {
          "command": "storybook build -c libs/ui/.storybook -o dist/storybook/ui"
        },
        "outputs": ["{workspaceRoot}/dist/storybook/ui"]
      },
      "storybook": {
        "executor": "nx:run-commands",
        "options": {
          "command": "storybook dev -c libs/ui/.storybook -p 6006"
        }
      }
    },
    "tags": [
      "scope:shared",
      "type:ui"
    ]
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react-native-css-interop": "0.2.3",
    "tailwind-merge": "^2.6.0",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": ">=0.79.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  }
}
